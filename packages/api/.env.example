# Mama Fua API — Environment Variables (Vercel/Production)
# KhimTech | 2026
# 
# For Vercel deployment:
# 1. Copy these variables to Vercel Project Settings → Environment Variables
# 2. Replace all YOUR_* values with actual production credentials
# 3. For local .env, use http://localhost values; for Vercel use HTTPS domains

# ── App Configuration ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://your-api-domain.com
FRONTEND_URL=https://your-frontend-domain.com
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://your-api-domain.com,https://your-admin-domain.com

# ── Database (PostgreSQL via Supabase/Vercel Postgres) ────────────────
DATABASE_URL=postgresql://user:password@host.postgres.vercel-storage.com/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host.postgres.vercel-storage.com/dbname?sslmode=require

# ── Redis (Upstash or similar) ─────────────────────────────────────────
REDIS_URL=redis://default:password@host.upstash.io:port

# ── JWT Keys (REQUIRED — generate with: openssl genrsa -out private.pem 2048) ─
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# ── M-Pesa Daraja (Production) ─────────────────────────────────────────
MPESA_CONSUMER_KEY=your_production_consumer_key
MPESA_CONSUMER_SECRET=your_production_consumer_secret
MPESA_SHORTCODE=your_production_shortcode
MPESA_PASSKEY=your_production_passkey
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CALLBACK_URL=https://your-api-domain.com/api/v1/webhooks/mpesa/stk
MPESA_B2C_RESULT_URL=https://your-api-domain.com/api/v1/webhooks/mpesa/b2c
MPESA_B2C_QUEUE_TIMEOUT_URL=https://your-api-domain.com/api/v1/webhooks/mpesa/b2c/timeout
MPESA_INITIATOR_NAME=your_production_initiator
MPESA_SECURITY_CREDENTIAL=your_production_credential

# ── Stripe (Payment Processing) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_live_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Google Maps (Location Services) ────────────────────────────────────
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key

# ── Africa's Talking (SMS) ────────────────────────────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_africas_talking_username
AT_SENDER_ID=MAMAFUA

# ── Firebase Admin SDK (Push Notifications) ────────────────────────────
# Generate from Firebase Console → Project Settings → Service Accounts → JSON key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","...":"..."}

# ── SendGrid (Email Delivery) ──────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@mamafua.co.ke

# ── Cloudinary (Image Upload & CDN) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Sentry (Error Tracking — Optional) ────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=info

