# Mama Fua API — Environment Variables
# KhimTech | 2026
# Copy this to .env and fill in your values

# ── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database (Supabase) ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mamafua_dev?sslmode=disable
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/mamafua_dev

# ── Redis (Upstash or local) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (generate with: openssl genrsa -out private.pem 2048) ─────────
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# ── M-Pesa Daraja ──────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-ngrok-url/api/v1/webhooks/mpesa/stk
MPESA_B2C_RESULT_URL=https://your-ngrok-url/api/v1/webhooks/mpesa/b2c
MPESA_INITIATOR_NAME=your_initiator
MPESA_SECURITY_CREDENTIAL=your_credential

# ── Stripe ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ── Google Maps ────────────────────────────────────────────────────────
GOOGLE_MAPS_SERVER_KEY=your_server_key

# ── Africa's Talking ───────────────────────────────────────────────────
AT_API_KEY=your_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=MAMAFUA

# ── Firebase FCM ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── SendGrid ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=noreply@mamafua.co.ke

# ── Cloudinary ─────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# ── Sentry ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_dsn@sentry.io/project

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=debug
