# Local Production Testing (.env.production.local)
# Use this to test production configuration locally before deploying to Vercel
# Never commit this file — add to .gitignore

# Copy from .env.example and fill with test credentials
# This allows testing database migrations, external services in prod mode

NODE_ENV=production
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8083

# Use local PostgreSQL (or Supabase staging)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mamafua_test?sslmode=disable
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/mamafua_test?sslmode=disable

# Use local Redis
REDIS_URL=redis://localhost:6379/1

# Use your actual JWT keys (from keygen)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# Use test/staging credentials (not production)
MPESA_CONSUMER_KEY=test_consumer_key
MPESA_CONSUMER_SECRET=test_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=test_passkey
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=http://localhost:3001/api/v1/webhooks/mpesa/stk
MPESA_B2C_RESULT_URL=http://localhost:3001/api/v1/webhooks/mpesa/b2c
MPESA_B2C_QUEUE_TIMEOUT_URL=http://localhost:3001/api/v1/webhooks/mpesa/b2c/timeout
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=test_credential

# Stripe test keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Optional services (test/staging keys)
GOOGLE_MAPS_SERVER_KEY=test_maps_key
AT_API_KEY=test_at_key
AT_USERNAME=sandbox
AT_SENDER_ID=MAMAFUA
FIREBASE_SERVICE_ACCOUNT_JSON={}
SENDGRID_API_KEY=SG.test_key
SENDGRID_FROM_EMAIL=noreply@test.mamafua.co.ke
CLOUDINARY_CLOUD_NAME=test_cloud
CLOUDINARY_API_KEY=test_key
CLOUDINARY_API_SECRET=test_secret

LOG_LEVEL=debug
